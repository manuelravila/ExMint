# ExMint Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (for plain local dev) or .env.dev / .env.stag /
# .env.main for Docker-based deployments, and fill in your values.
#
# All secrets can be provided as plain environment variables (recommended for
# self-hosters) or fetched automatically from Bitwarden Secrets Manager when
# BWS_ACCESS_TOKEN is set (optional — see bottom of file).
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
FLASK_ENV=dev                         # dev | stag | main

# ── Database (MySQL / MariaDB) ────────────────────────────────────────────────
DB_USER=exmint
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=exmint

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# ── Plaid ─────────────────────────────────────────────────────────────────────
# Sign up at https://plaid.com/docs/quickstart/ — sandbox credentials are free
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
# Optional: only needed if you want Plaid to push transaction updates to you
# PLAID_WEBHOOK_URL=https://your-domain.com/api/plaid/webhook

# ── Email (password reset) ────────────────────────────────────────────────────
MAIL_SERVER=smtp.your-provider.com
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=your_mail_password
MAIL_PORT=587

# ── Application URL ───────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email address that receives new registration approval requests.
# Leave blank to skip admin notifications (registrations still go to PendingApproval).
ADMIN_EMAIL=your@email.com

# ── Test User Cleanup (optional) ─────────────────────────────────────────────
# Email of a shared test/demo account whose data is wiped nightly by
# cleanup_test_user.py. Leave blank to disable the cleanup.
TEST_USER_EMAIL=

# ── Docker networking (optional) ─────────────────────────────────────────────
# CRON_IP is the fixed IP assigned to the cron container inside the Docker
# network. Must be in the same subnet as FLASK_IP.
# CRON_IP=172.21.0.4

# ── (Optional) Bitwarden Secrets Manager ─────────────────────────────────────
# If BWS_ACCESS_TOKEN is set, secrets above will be fetched from Bitwarden
# instead of environment variables. This is the maintainer's deployment path —
# self-hosters do not need this.
# BWS_ACCESS_TOKEN=your_bws_access_token
