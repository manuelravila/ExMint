{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ExMint PROD",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_SYS": "linux"
      },
      "envFile": "${workspaceFolder}/.env.main",
      "args": [
        "run",
        "--no-debugger",
        "--no-reload",
        "--host=127.0.0.1",
        "--port=5000"
      ],
      "jinja": true,
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "Open Prod DB tunnel"
    },
    {
      "name": "ExMint DEV",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_SYS": "linux",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/.env.dev",
      "args": [
        "run",
        "--no-debugger",
        "--no-reload",
        "--host=127.0.0.1",
        "--port=5000"
      ],
      "jinja": true,
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "Open Dev DB tunnel"
    }
  ]
}
