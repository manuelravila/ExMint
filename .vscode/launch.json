{
    "version": "0.2.0",
    "configurations": [
      
      {
        "type": "msedge",
        "request": "launch",
        "name": "Launch Office Add-in",
        "url": "https://dev.exmint.me:3000/taskpane.html",
        "webRoot": "${workspaceFolder}",
        "sourceMaps": true,
        "sourceMapPathOverrides": {
          "webpack:///./*": "${webRoot}/*",
          "webpack:///*": "*",
          "webpack:///src/*": "${webRoot}/src/*"
        }
      }
    ]
  }