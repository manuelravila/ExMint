            {
              "Header": "Account Name",
              "Width": 20.86,
              "Formula": "=IFERROR(XLOOKUP([@[Account ID]], Accounts[Plaid Account ID], Accounts[Name]),\"Account Not Found\")"
            },
            {
              "Header": "Bank",
              "Width": 14,
              "Formula": "=XLOOKUP([@[Account ID]],Accounts[Plaid Account ID],Accounts[Institution Name],\"Not Found\",0)"
            },
            {
              "Header": "Operation",
              "Width": 10.71,
              "Formula": "=IF([@Amount]<0,\"credit\",\"debit\")"
            },
            {
              "Header": "Custom Category",
              "Width": 16.29,
              "Formula": "=LET(    name_match, ISNUMBER(SEARCH(LOWER(Custom_Cat[Name]), LOWER([@Name]))),    name_length, LEN(Custom_Cat[Name]) >= 3,    amount_check,        IF(Custom_Cat[Amount] = \"0|\",            [@Amount] >= 0,            IF(ISNUMBER(VALUE(Custom_Cat[Amount])),                [@Amount] = VALUE(Custom_Cat[Amount]),                LET(                    split, FIND(\"|\", Custom_Cat[Amount]&\"|\"),                    left_val, IF(split>1, VALUE(LEFT(Custom_Cat[Amount], split-1)), -1E+300),                    right_val, IF(LEN(Custom_Cat[Amount])>split, VALUE(MID(Custom_Cat[Amount], split+1, 999)), 1E+300),                    AND([@Amount] >= left_val, [@Amount] <= right_val)                )            )        ),    match_all, name_match * name_length * amount_check,    category_match, ISNUMBER(MATCH([@Categories], FILTER(Custom_Cat[Name], LEN(Custom_Cat[Name]) >= 3), 0)),    IF(COUNTA(Custom_Cat[Name]) = 1,        IF(match_all, Custom_Cat[Custom Category], [@Categories]),        IF(category_match,            INDEX(Custom_Cat[Custom Category], MATCH([@Categories], FILTER(Custom_Cat[Name], LEN(Custom_Cat[Name]) >= 3), 0)),            IFERROR(                INDEX(Custom_Cat[Custom Category], MATCH(1, match_all, 0)),                [@Categories]            )        )    ))"
            },
            {
              "Header": "Month",
              "Width": 10.43,
              "Formula": "=DATE(YEAR([@Datetime]),MONTH([@Datetime]),1)"
            },
            {
              "Header": "Recent",
              "Width": 15,
              "Formula": "=AND([@Datetime]>=EDATE(MAX([Datetime]),-6),[@Datetime]<=TODAY())"
            },
            {
              "Header": "6M AVG",
              "Width": 8.43,
              "Formula": "=IFERROR(AVERAGEIFS([Month''s Total],[Recent],TRUE,[Custom Category],[@[Custom Category]]),0)"
            },
            {
              "Header": "Month's Total",
              "Width": 10.86,
              "Formula": "=SUMIFS([Amount],[Month],[@Month],[Custom Category],[@[Custom Category]])"
            },
            {
              "Header": "Budget",
              "Width": 8.43,
              "Formula": "=IF(COUNTIF(Budgets[Custom Category],[@[Custom Category]])=0,[@[6M AVG]],XLOOKUP([@[Custom Category]],Budgets[Custom Category],Budgets[Monthly],0,0))"
            },
            {
              "Header": "Sel Month",
              "Width": 8.43,
              "Formula": "=IF([@Month]=Sel_Month,[@Amount],0)"
            }
