              "Width": 35.71,
              "Formula": ""
            },
            {
              "Header": "Account Name",
              "Width": 39.57,
              "Formula": "=IFERROR(XLOOKUP([@[Account ID]], Accounts[Plaid Account ID], Accounts[Name]),\"Account Not Found\")"
            },
            {
              "Header": "Bank",
              "Width": 15.29,
              "Formula": "=XLOOKUP([@[Account ID]],Accounts[Plaid Account ID],Accounts[Institution Name],\"Not Found\",0)"
            },
            {
              "Header": "Custom Category",
              "Width": 29.86,
              "Formula": "=LET(    customCatName, Custom_Cat[Name],    customCatCategory, Custom_Cat[Category],    customCatAmountMin, Custom_Cat[Amount >=],    customCatAmountMax, Custom_Cat[Amount <=],    customCatResult, Custom_Cat[Custom Category],    transName, UPPER([@Name]),    transCategory, UPPER([@Categories]),    transAmount, -[@Amount],    namePresent, LEN(customCatName) > 2,    categoryPresent, LEN(customCatCategory) > 2,    minAmountPresent, NOT(ISBLANK(customCatAmountMin)),    maxAmountPresent, NOT(ISBLANK(customCatAmountMax)),    nameMatches, IF(namePresent, ISNUMBER(SEARCH(UPPER(customCatName), transName)), TRUE),    categoryMatches, IF(categoryPresent, ISNUMBER(SEARCH(UPPER(customCatCategory), transCategory)), TRUE),    minAmountMatches, IF(minAmountPresent, transAmount >= customCatAmountMin, TRUE),    maxAmountMatches, IF(maxAmountPresent, transAmount <= customCatAmountMax, TRUE),    validRule, OR(namePresent, categoryPresent, minAmountPresent, maxAmountPresent),    fullMatch, nameMatches * categoryMatches * minAmountMatches * maxAmountMatches * validRule,    nameAndCategoryMatch, nameMatches * categoryMatches * namePresent * categoryPresent * minAmountMatches * maxAmountMatches,    nameOnlyMatch, nameMatches * namePresent * (NOT(categoryPresent)) * minAmountMatches * maxAmountMatches * validRule,    categoryOnlyMatch, categoryMatches * categoryPresent * (NOT(namePresent)) * minAmountMatches * maxAmountMatches * validRule,    lastNameAndCategoryMatch, IFERROR(LOOKUP(2, 1/(nameAndCategoryMatch), customCatResult), \"\"),    lastNameOnlyMatch, IFERROR(LOOKUP(2, 1/(nameOnlyMatch), customCatResult), \"\"),    lastCategoryOnlyMatch, IFERROR(LOOKUP(2, 1/(categoryOnlyMatch), customCatResult), \"\"),    lastFullMatch, IFERROR(LOOKUP(2, 1/(fullMatch), customCatResult), \"\"),    IF(lastNameAndCategoryMatch <> \"\", lastNameAndCategoryMatch,       IF(lastNameOnlyMatch <> \"\", lastNameOnlyMatch,          IF(lastCategoryOnlyMatch <> \"\", lastCategoryOnlyMatch,             IF(lastFullMatch <> \"\", lastFullMatch, [@Categories])))))"
            },
            {
              "Header": "Month",
              "Width": 9.71,
              "Formula": "=DATE(YEAR([@Datetime]),MONTH([@Datetime]),1)"
            },
            {
              "Header": "6M AVG",
              "Width": 7.29,
              "Formula": "=IFERROR(ABS(AVERAGEIFS([Month''s Total],[Datetime],\">=\"&EDATE([@Month],-6),[Datetime],\"<\"&[@Month],[Custom Category],[@[Custom Category]])),0)"
            },
            {
              "Header": "Month's Total",
              "Width": 9.57,
              "Formula": "=ABS(SUMIFS([Amount],[Month],[@Month],[Custom Category],[@[Custom Category]]))"
            },
            {
              "Header": "Budget",
              "Width": 7.29,
              "Formula": "=IF(COUNTIF(Budgets[Custom Category],[@[Custom Category]])=0,[@[6M AVG]],XLOOKUP([@[Custom Category]],Budgets[Custom Category],Budgets[Monthly],0,0))"
            },
            {
              "Header": "Remainder",
              "Width": 7.29,
              "Formula": "=ABS([@Budget])-ABS(SUMIFS([Amount],[Custom Category],[@[Custom Category]],[Month],[@Month]))"
            }
          ],
