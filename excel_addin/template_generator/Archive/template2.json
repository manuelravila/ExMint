      "Notes": [
        {
          "Cell": "$A$1",
          "HTMLText": "Account id used by ExMint to connect this table with the Accounts table.",
          "Width": 123,
          "Height": 63
        },
        {
          "Cell": "$B$1",
          "HTMLText": "Most recent action taken by ExMint on the record. You can safely delete the lines flagged as \"removed\"",
          "Width": 129.75,
          "Height": 69
        },
        {
          "Cell": "$C$1",
          "HTMLText": "Transaction amount. Negative for debit/loan/spend operations and positive for credit/income transactions.",
          "Width": 159.75,
          "Height": 56.25
        },
        {
          "Cell": "$D$1",
          "HTMLText": "This is an AUTOMATIC categorization that PLAID applies to every transaction based on the merchant. You can edit this value to assign a custom category to a specific transaction instead of using the Custom Category table. NOTE 1: Custom Category rules will still be applied to edited values in this column. NOTE 2: If the transaction is not settled, i. e. , Pending column = TRUE then the entire row will be rewritten in a future sync when the transaction is settled.",
          "Width": 246,
          "Height": 127.5
        },
        {
          "Cell": "$E$1",
          "HTMLText": "Date and time when the transaction was recorded",
          "Width": 157.5,
          "Height": 81.75
        },
        {
          "Cell": "$F$1",
          "HTMLText": "Currency the transaction was settled in.",
          "Width": 108,
          "Height": 43.5
        },
        {
          "Cell": "$G$1",
          "HTMLText": "Name or identification of the merchant who received the payment. NOTE: This value is NOT always present.",
          "Width": 159,
          "Height": 63.75
        },
        {
          "Cell": "$H$1",
          "HTMLText": "Description of the transaction as recorded by the merchant and reported by the financial institution to Plaid.",
          "Width": 179.25,
          "Height": 79.5
        },
        {
          "Cell": "$I$1",
          "HTMLText": "Identifies whether the transaction was made online, on a store or at an unidentified location (other).",
          "Width": 144,
          "Height": 66.75
        },
        {
          "Cell": "$J$1",
          "HTMLText": "This column is TRUE when the transaction is still not settled, which means that the transaction may be adjusted, cancelled or confirmed at a future sync.",
          "Width": 159.75,
          "Height": 78
        },
        {
          "Cell": "$K$1",
          "HTMLText": "Internal unique identifier used by PLAID and ExMint for every transaction.",
          "Width": 175.5,
          "Height": 74.25
        },
        {
