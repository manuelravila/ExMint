              "Width": 20.86,
              "Formula": "=IFERROR(XLOOKUP([@[Account ID]], Accounts[Plaid Account ID], Accounts[Name]),\"Account Not Found\")"
            },
            {
              "Header": "Bank",
              "Width": 14,
              "Formula": "=XLOOKUP([@[Account ID]],Accounts[Plaid Account ID],Accounts[Institution Name],\"Not Found\",0)"
            },
            {
              "Header": "Operation",
              "Width": 10.71,
              "Formula": "=IF([@Amount]<0,\"credit\",\"debit\")"
            },
            {
              "Header": "Custom Category",
              "Width": 16.29,
              "Formula": "=IF(    ISNUMBER(MATCH([@Categories], FILTER(Custom_Cat[Name], LEN(Custom_Cat[Name]) >= 3), 0)),    INDEX(Custom_Cat[Custom Category], MATCH([@Categories], FILTER(Custom_Cat[Name], LEN(Custom_Cat[Name]) >= 3), 0)),    IFERROR(        INDEX(            Custom_Cat[Custom Category],            MATCH(                1,                (ISNUMBER(SEARCH(LOWER(Custom_Cat[Name]), LOWER([@Name]))))                * (LEN(Custom_Cat[Name]) >= 3)                * (                    (IF(LEFT(Custom_Cat[Amount],1)=\"<\",[@Amount]<VALUE(MID(Custom_Cat[Amount], 2, LEN(Custom_Cat[Amount])-1)),TRUE))                    * (IF(LEFT(Custom_Cat[Amount],1)=\">\",[@Amount]>VALUE(MID(Custom_Cat[Amount], 2, LEN(Custom_Cat[Amount])-1)),TRUE))                ),                0            )        ),        [@Categories]    ))"
            },
            {
              "Header": "Month",
              "Width": 10.43,
              "Formula": "=DATE(YEAR([@Datetime]),MONTH([@Datetime]),1)"
            },
            {
              "Header": "Recent",
              "Width": 15,
              "Formula": "=AND([@Datetime]>=EDATE(MAX([Datetime]),-6),[@Datetime]<=TODAY())"
            },
            {
              "Header": "6M AVG",
              "Width": 8.43,
              "Formula": "=IFERROR(AVERAGEIFS([Month''s Total],[Recent],TRUE,[Custom Category],[@[Custom Category]]),0)"
            },
            {
              "Header": "Month's Total",
              "Width": 10.86,
              "Formula": "=SUMIFS([Amount],[Month],[@Month],[Custom Category],[@[Custom Category]])"
            },
            {
              "Header": "Budget",
              "Width": 8.43,
              "Formula": "=IF(COUNTIF(Budgets[Custom Category],[@[Custom Category]])=0,[@[6M AVG]],XLOOKUP([@[Custom Category]],Budgets[Custom Category],Budgets[Monthly],0,0))"
            },
            {
              "Header": "Sel Month",
              "Width": 8.43,
              "Formula": "=IF([@Month]=Sel_Month,[@Amount],0)"
            }
